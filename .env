APP_NAME=LadaPala-Bill
APP_ENV=local
APP_KEY=base64:placeholder_will_be_generated
APP_DEBUG=true
APP_URL=http://localhost

# ========================================
# SERVER 1: BILLING DATABASE (PostgreSQL)
# ========================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=billing_db
DB_USERNAME=ladapala
DB_PASSWORD=secret

# ========================================
# SERVER 3: FREERADIUS DATABASE (MySQL Remote)
# ========================================
RADIUS_DB_HOST=10.0.0.3
RADIUS_DB_PORT=3306
RADIUS_DB_DATABASE=radius
RADIUS_DB_USERNAME=radius_sync
RADIUS_DB_PASSWORD=secret

# ========================================
# SERVER 2: MIKROTIK / BRAS
# ========================================
MIKROTIK_DEFAULT_PORT=8728
MIKROTIK_SSL_PORT=8729

# ========================================
# SERVER 4: WA GATEWAY
# ========================================
WA_GATEWAY_URL=http://10.0.0.4:3000
WA_GATEWAY_API_KEY=

# ========================================
# CACHE & QUEUE (Redis)
# ========================================
CACHE_STORE=file
QUEUE_CONNECTION=redis
SESSION_DRIVER=file

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ========================================
# MULTI-TENANT
# ========================================
TENANT_RESOLUTION=subdomain
# Options: subdomain, header, session

# ========================================
# LICENSE
# ========================================
LICENSE_SERVER_URL=https://license.ladapala.com
LICENSE_KEY=
LICENSE_CACHE_HOURS=24
LICENSE_GRACE_DAYS=7

# ========================================
# NOTIFICATIONS
# ========================================
FCM_SERVER_KEY=
FCM_SENDER_ID=

# ========================================
# MAIL (optional)
# ========================================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525

# ========================================
# LOGGING
# ========================================
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ========================================
# MISC
# ========================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
